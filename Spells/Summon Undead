   --!a:[&SpiritID]|hp:[$HP]
   --!a:[&SpiritID]|hp^:[$HP]
   
   --/|Set AC and Prof Bonus
   --!a:[&SpiritID]|npc_ac:[$AC]
   --!a:[&SpiritID]|npc_pb:[$PB]
   --!a:[&SpiritID]|npc_speed:[&Speed]
   
   --/|Set Traits Block
   --?[&Shape] -eq putrid|[
    --rbyindex|[&SpiritID];repeating_npctrait;0
    --!a:[&SpiritID]|![*R>description]:[&FesteringDesc]
	--]|
   
   --rbyindex|[&SpiritID];repeating_npcaction;0

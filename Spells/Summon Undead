   --&[%2%]|[@SpiritCharArr(0)]
   --<|
  
  --:DetermineStats|
   --=HPMod|[$SpellLevel]-3
   --=HPMod|[$HPMod]*10
   --=HP|[$BaseHP]+[$HPMod] 
   --=AC|11+[$SpellLevel]

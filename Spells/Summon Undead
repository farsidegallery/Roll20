   --+|[c][rbutton]Ghostly::Summon;ghost[/rbutton][rbutton]Putrid::Summon;putrid[/rbutton][rbutton]Skeletal::Summon;skeletal[/rbutton][/c]
   --X|
   
  --:Summon|
   --&Shape|[&reentryval]
   --#whisper|
   --#rightsub|[&Shape] Undead
   --c[&Shape]|ghost:=side;1|putrid:=side;2|skeletal:=side;3
   --c[$side]|1:&Speed;30 ft., fly 40 ft. (hover)|2:&Speed;30 ft.|3:&Speed;30 ft.
   --?[$side] -eq 3|=BaseHP;20 |=BaseHP;30
   -->DetermineStats|
   --!c:[&SpiritID]|controlledby:[&control]
   --+Duration: |[&duration]
   --+Desc: |[&spelldesc]
   --+At Higher Levels: |[&spellhigherdesc]
   -->far_DeductSpellSlot|[*S:t-id];[$SpellLevel]
   --!a:[*S:character_id]|!ConcentrationSpell:[&SpiritName]
   -->LibSN_ADD_STATUS_MARKER|[*S:t-id];[&ConcentrationMarker];
   --@forselected+|Spawn _name|[&SpiritName] _qty|1 _bar1|[$HP] _bar2|[$AC]/ _side|[$side] _offset|1,1 _force|yes _tokenProps|name:[&SpiritName],showname:true,showplayers_name:true _order|toFront _fx|nova-magic _expand|15,30 {^&select @{selected|token_id}}
   --X|
  
  --:GetSpiritID|CharacterName;StringVariableForCharID
   --~|array;objects:character;SpiritCharArr;[%1%]

!script{{
  +++5Elib;snlib;Farsidelib+++	
 
  --#title|Spiritual Weapon
  --#sourceToken|@{selected|token_id}
  --#reentrant|My Cool Script @{selected|character_id}
  --#whisper|self,gm

  --/|Script Name : Spiritual Weapon
  --/|Version     : 2.0
  --/|Requires SC : Spawn, SelectManager, ChatSetAttr, ScriptCards Library snlib/Farsidelib
  --/|Author      : Farsidegallery
  --/|  
  --/|  Script prompts user for spell level used and then queries for shape of the weapon. It will deduct 1 spell slot from the appropriate level and spawn the designated token to the VTT. Script calculates
  --/|  attack roll, enemy AC, and damage. Script outputs results to chat and deducts damage from the enemy.
  --/|
  
  --/| ____________________ Begin Global User Variables -Update the variables below to your game settings. ___________________________________
    
  --/|Enter name for Spiritual Weapon Character.
  --&WeaponName|[*S:character_name] Spiritual Weapon
  
  --&SpellName|Spiritual Weapon
  --&MinimumSpellLevel|2
  --&damageType|radiant
  
  --&damageType|fire
   
  --&hpBar|1
  --&tempHPbar|4
  
  --/|Put the name of your check if custom crit damage will be applied.
  --&CustomCritCheck|far_CustomCritCheck
   
  --/|Define your custom crit damage dice roll modifier, roll type, roll modifier, and extra damage modifier
  --/|ex 1: 2d8+8 is -1 dicemodifier (making 2d8), d dicerolltype, blank rollmodifier, and with +8 damagemodifier
  --/|ex 2: 3d8 keep highest one is blank dicemodifier, with d dicerolltype, kh1 for rollmodifier, and blank for damagemodifier
  --/|ex 3: 3d8 max all dice is blank dicemodifier, m dicerolltype, blank rollmodifier, and blank damagemodifier
  --&CritDamageDiceModifier|-1
  --&CritDamageDiceRollType|d
  --&CritDamageRollModifier|
  --=CritDamageModifier|+8
      
  --/|Are you using the matching Bardic Inspiration Script from FarsideGallery? (Default is No using 0. Change to 1 if using the script.)
  --=Scriptcheck|1
  
  --/|Enter the Token Markers you use for each condition
  --&BardicMarker|BardicInspiration::7409920
  --&BlessedMarker|angel-outfit
  --&InspirationMarker|Inspiration::7409921
  --&BaneMarker|Hexed3::7409911
  --&HexMarker|Hexed::7409913
  --&HexBladebladeMarker|Hexed2::7409912
  --&DeathMarker|dead
  
  --/| ____________________ End Global User Variables ___________________________________________________________________________________________

  --/|Helper variable build up to allow us to include a target prompt in an rbutton
  --&TB|& --&TB|+# --&TB|+64 --&TB|+; --&TB|+{
  --&SPACE|X X --&SPACE|[&SPACE(1,1)]
  --&brace|{
  --&cbrace|}
  --&obrac|[ 
  --&cbrac|]
  --&oparen|(
  --&cparen|)
 
  -->GetSpiritID|[&WeaponName];WeaponID
  --&control|[*O:[*S:t-represents]:character:controlledby]
  --Rfind|[*S:character_id];[&SpellName];repeating_spell-[&MinimumSpellLevel];spellname
  --?"[*R:spellname]" -eq "NoRepeatingAttributeLoaded"|>far_FatalError;Spell Not Found;ERROR;Could not find a level [&MinimumSpellLevel] spell named [&SpellName]
  -->ChooseFunction|
  
  --:ChooseFunction|
   --+Choose Function: |[rbutton]New Cast::ChooseLevel[/rbutton][rbutton]Attack::ChooseTarget[/rbutton][rbutton]Dismiss::Remove[/rbutton]
   --X|
  
  --:ChooseLevel|
   -->far_GetAvailableSpellLevels|[*S:character_id];[&MinimumSpellLevel];SpellCastLevel
   --?[@SpellCastLevel(length)] -eq 0|>far_FatalError;No Spell Slots Available;ERROR;No spell slots are available to cast [&SpellName]
   
   --+|[c][b]Cast At What Level?[/b][/c]
    --&splvlMsg|
    --%splvl|foreach;SpellCastLevel
     --&splvlMsg|+ [rbutton][&splvl]::ChooseType;[&splvl][/rbutton]
    --%|
  --+|[c][&splvlMsg][/c]
  --X|
  
  --:ChooseType|
   --=SpellLevel|[&reentryval]
   --&SpellLevel|[&reentryval]
   --#leftsub|[*R:spellcastingtime]
   --#rightsub|[*R:spellrange]
   --&spelldesc|[*R:spelldescription]
   --&spellhigherdesc|[*R:spellathigherlevels]
   --?[*R:spellconcentration] -inc 1|&duration;[*R:spellduration] [b](Concentration)[/b]|&duration;[*R:spellduration]
   
   --+Choose Weapon: |[br]
   --+|[rbutton]BattleAxe::NewCast;BattleAxe[/rbutton][rbutton]Club::NewCast;Club[/rbutton][rbutton]Dagger::NewCast;Dagger[/rbutton][rbutton]Flail::NewCast;Flail[/rbutton][rbutton]Glaive::NewCast;Glaive[/rbutton][rbutton]GreatAxe::NewCast;GreatAxe[/rbutton][rbutton]GreatClub::NewCast;GreatClub[/rbutton][rbutton]GreatSword::NewCast;GreatSword[/rbutton][rbutton]Halberd::NewCast;Halberd[/rbutton][rbutton]HandAxe::NewCast;HandAxe[/rbutton][rbutton]Javelin::NewCast;Javelin[/rbutton][rbutton]Lance::NewCast;Lance[/rbutton][rbutton]LightHammer::NewCast;LightHammer[/rbutton][rbutton]Longsword::NewCast;Longsword[/rbutton][rbutton]Mace::NewCast;Mace[/rbutton][rbutton]Maul::NewCast;Maul[/rbutton][rbutton]MorningStar::NewCast;MorningStar[/rbutton][rbutton]Pike::NewCast;Pike[/rbutton][rbutton]Quarterstaff::NewCast;Quarterstaff[/rbutton][rbutton]Rapier::NewCast;Rapier[/rbutton][rbutton]scimitar::NewCast;scimitar[/rbutton][rbutton]Shortsword::NewCast;Shortsword[/rbutton][rbutton]Sickle::NewCast;Sickle[/rbutton][rbutton]Spear::NewCast;Spear[/rbutton][rbutton]Trident::NewCast;Trident[/rbutton][rbutton]WarHammer::NewCast;WarHammer[/rbutton][rbutton]Warpick::NewCast;Warpick[/rbutton]  {&skip}
   --X|
  
  --:ChooseTarget|
   --+Attack|[rbutton]Click this button to select your target.::Attack;&#64;{target|token_id}[/rbutton]
   --X|  

  --:NewCast|
   --&Weapon|[&reentryval]
   --#emoteText|[*S:character_name] Casts Spiritual Weapon shaped as an [&Weapon]!
   --C[&Weapon]|BattleAxe:=Side;1|Club:=Side;2|Dagger:=Side;3|Flail:=Side;4|Glaive:=Side;5|GreatAxe:=Side;6|GreatClub:=Side;7|GreatSword:=Side;8|Halberd:=Side;9|HandAxe:=Side;10|Javelin:=Side;11|Lance:=Side;12|LightHammer:=Side;13|Longsword:=Side;14|Mace:=Side;15|Maul:=Side;16|MorningStar:=Side;17|Pike:=Side;18|Quarterstaff:=Side;19|Rapier:=Side;20|scimitar:=Side;21|Shortsword:=Side;22|Sickle:=Side;23|Spear:=Side;24|Trident:=Side;25|WarHammer:=Side;26|Warpick:=Side;27|
   --!a:[&WeaponID]|!Weapon:[&Weapon]
   --!a:[&WeaponID]|!Weapon_Level:[$SpellLevel]
   -->far_GetAndCheckSlotInformation|[*S:t-id];[$SpellLevel]
   -->far_DeductSpellSlot|[*S:t-id];[$SpellLevel]
   --!a:[*S:character_id]|!ConcentrationSpell:[&SpellName]
   --!a:[*S:character_id]|!ConcentrationSpellTargetToken:[&WeaponName]
   
   --!c:[&WeaponID]|controlledby:[&control]
   --@forselected+|Spawn _name|[&WeaponName] _qty|1 _bar1|5/ _placement|surround _side|[$Side] _offset|1,1 _force|yes _tokenProps|name:[&WeaponName],showname:true,showplayers_name:true _order|toFront _fx|nova-magic _expand|15,30 _isDrawing|1 {^&select @{selected|token_id}}
   -->ChooseTarget|
   --X|
  
  --:Attack|
   --#targettoken|[&reentryval]
   --#whisper|
   --&spelldesc|[*R:spelldescription]
   --&spellhigherdesc|[*R:spellathigherlevels]
   --?[*R:spellconcentration] -inc 1|&duration;[*R:spellduration] [b](Concentration)[/b]|&duration;[*R:spellduration]
   
   -->LibSN_CHECK_STATUS_MARKER|[*S:t-id];[&InspirationMarker];InspiredFlag;InspiredCount
   -->LibSN_CHECK_STATUS_MARKER|[*S:t-id];[&BardicMarker];BardicFlag;BardicCount
   -->LibSN_CHECK_STATUS_MARKER|[*S:t-id];[&BlessedMarker];BlessFlag;BlessCount
   
   --=SlotLevel|[*[&WeaponID]:Weapon_Level]
   --=DiceCount|[$SlotLevel]\2
   --&DamageDice|[$DiceCount]
   --&AttackWeapon|[*[&WeaponID]:Weapon]
   --#emoteText|[*S:character_name] attacks [*T:character_name] with a Spiritual Weapon shaped as an [&AttackWeapon]!

   ---=TargetHP|[*T:t-bar1_value]
   --?[*T:npc] -eq 1|=TargetAC;[*T:npc_ac]|=TargetAC;[*T:ac]
   -->far_CheckDamageModifiers|[*T:character_id];[&damageType];damageMod;1;0;0
   -->LibSN_CHECK_STATUS_MARKER|[*T:t-id];[&HexMarker];HexMarkerFlag;HexMarkerCount
   -->LibSN_CHECK_STATUS_MARKER|[*T:t-id];[&HexBladeMarker];HexBladeMarkerFlag;HexBladeMarkerCount
   --?[*T:npc] -eq 1|=TargetAC;[*T:npc_ac]|=TargetAC;[*T:ac]
   
   --+|[c]Choose Attack Type:[/c]
   --+|[c][rbutton]Advantage::AttackType;2d20kh1[/rbutton][rbutton]Normal::AttackType;1d20[/rbutton][rbutton]Disadvantage::AttackType;2d20kl1[/rbutton][/c]
   --X|
   
  --:AttackType|
   --&AttackDice|[&reentryval]
   --?[&InspiredFlag] -ne 0 |>far_Inspiration;[*S:t-id];[&InspirationMarker];[&AttackDice];AttackDice
   
   --=AttackDiceBase|[&AttackDice]
   --+Rolling [&AttackDice]: |[$AttackDiceBase]
   --+|[br]
   --=AttackRollMod|[$AttackDiceBase] + [*S:spell_attack_bonus] [Spell Attack Bonus]
   
   --?[&BardicFlag] -eq 1|>far_Bardic;[*S:t-id];[&BardicMarker];[$Scriptcheck];[$AttackDiceBase];[$AttackRollMod];BardRoll
   --?[&BaneMarkerFlag] -eq 1|&Baneroll;+ - 1d4 [Bane] |&Baneroll;
   
   --=AttackRoll|[$AttackDiceBase] + [*S:spell_attack_bonus] [Spell Attack Bonus] [&GlobalAttack] [&Baneroll] [&BardRoll]
   
   --+Total Attack R

   --?[$AttackDiceBase] -eq 20|>Crit
   --?[$AttackDiceBase] -eq 1|>Fumble
   --?[$AttackRoll] -ge [$TargetAC.Total] -and [$AttackDiceBase] -nei 20|>Hit
   --?[$AttackRoll] -lt [$TargetAC.Total] -and [$AttackDiceBase] -nei 1|>Miss
   --X|

  --/| ____________________ Procedures_______________________________________________________________________________________
  

  --:Crit|
   --#whisper|
   -->far_FIND_ACTIVE_GLOBAL_DAMAGE_MODS|[*S:character_id];GlobalDamage;1   
   --?"X[&HexMarkerFlag]" -eq "X1" -and "X[*S:ConcentrationSpellTargetToken]" -eqi "X[*T:t-id]"|&Hex;+ + 1d6 [Hex] |&Hex;
   --?"X[&HexBladeMarkerFlag]" -eq "X1" -and "X[*S:CurseTarget]" -eq "X[*T:t-id]"|&HexBlade;+ + [*S:pb] [Proficiency Bonus] |&HexBlade;
   -->[&CustomCritCheck]|CustomCritFlag
   --?[&CustomCritFlag] -eq 1|[
    --=CritDice|[&DamageDice]+[&CritDamageDiceModifier]
    --&CritDamage|[$CritDice][&CritDamageDiceRollType]8[&CritDamageRollModifier] + [$CritDamageModifier]
    --=Damage|[&DamageDice]d8 [Hit] + [&CritDamage] [Crit] [&HexBlade] [&Hex] [&GlobalDamage][&damageMod]
	--]|[
	--=Damage|[&DamageDice]d8 [Hit] + [&DamageDice]d8 [Crit] [&HexBlade] [&Hex] [&GlobalDamage][&damageMod]
	--]|
   --+[b]Critical Hit!!![/b] |The attack did [$Damage] points of [&damageType] damage.
   --/|>LibSN_APPLY_DAMAGE_OR_HEALING|[*T:t-id];1;-[$Damage];0;0;1
   -->far_DamageTokenmod|[*T:t-id];[&hpBar];[&tempHPbar];-[$Damage];0;0;1
   --=FinalHP|[$TargetHP]-[$Damage]
   --?[$FinalHP] -le 0|>Died
   -->Output|
   --X|

  --:Hit|
   --#whisper|
   -->far_FIND_ACTIVE_GLOBAL_DAMAGE_MODS|[*S:character_id];GlobalDamage;0
   --?"X[&HexMarkerFlag]" -eq "X1" -and "X[*S:ConcentrationSpellTargetToken]" -eqi "X[*T:t-id]"|&Hex;+ + 1d6 [Hex] |&Hex;
   --?"X[&HexBladeMarkerFlag]" -eq "X1" -and "X[*S:CurseTarget]" -eq "X[*T:t-id]"|&HexBlade;+ + [*S:pb] [Proficiency Bonus] |&HexBlade;
   --=Damage|[&DamageDice]d10 [&HexBlade] [&Hex][&GlobalDamage][&damageMod]
   --+[b]Hit![/b] |Spiritual [&AttackWeapon] hits [*T:character_name] for [$Damage] hp.
   --/|>LibSN_APPLY_DAMAGE_OR_HEALING|[*T:t-id];1;-[$Damage];0;0;1
   -->far_DamageTokenmod|[*T:t-id];[&hpBar];[&tempHPbar];-[$Damage];0;0;1
   --=FinalHP|[$TargetHP]-[$Damage]
   --?[$FinalHP] -le 0|>Died
   -->Output|
   --X|

  --:Miss|
   --#whisper|
   --+[b]Missed![/b] |So close but [*T:t-name] ducked just in time. Better luck next time (if there is a next time).
   -->Output|
   --X|

  --:Fumble|
   --#whisper|
   --+[b]Fumble![/b] |The attack went horribly wrong.
   --=Fail|[T#Damage-Spell-Fail]
   --&failText|[$Fail.tableEntryText]
   --?"[&failText]" -inc "[&obrac][&obrac]"|[
	--~failText1|string;before;[&obrac][&obrac];[&failText]
	--~failText2|string;after;[&cbrac][&cbrac];[&failText]
	--~roll|string;before;[&cbrac][&cbrac];[&failText]
	--~roll|string;after;[&obrac][&obrac];[&roll]
	--=failRoll|[&roll]
	--&failText|[&failText1][$failRoll][&failText2]
	--]|
   --+|[br]
   --+|[&failText]
   --?"[&failText]" -inc "Roll for damage"|[
    --=Damage|[&DamageDice]d8
	--+|[br]
	--+Damage: |[$Damage]
	--]|
   
   --X|   

  --:Died|
   -->LibSN_ADD_STATUS_MARKER|[*T:t-id];[&DeathMarker]
   --<|
   
  --:Output| 
   --+|[br]
   --+Duration: |[&duration]
   --+Desc: |[*R:spelldescription]
   --+At Higher Levels: |[*R:spellathigherlevels]
   --X|
  
 --:Remove|
   --#targetToken|[&reentryval]
   --!a:[&WeaponID]|!Weapon:**
   --!a:[&WeaponID]|!Weapon_Level:**
   -->LibSN_REMOVE_STATUS_MARKER|[*S:t-id];Concentrating::7409928

	  --!ot:NewTID|name:"[&SleepToken]"|_pageid:[*S:t-_pageid]|left:[*[&loop]:t-left]|top:[*[&loop]:t-top]|width:[=[*[&loop]:t-width]*2]|height:[=[*[&loop]:t-height]*2]|imgsrc:"[&SleepLink]"|bar1_value:1|represents:"[&SleepChar]"|showname:0
	  --z:graphic:[&NewTID]|toback
	  --@CARRY_TOKENS_CARRY_BELOW|[*[&loop]:t-id] [&NewTID]
	  --]|[
	  --+|[t border=3 width=100%][td style="width:175px"][*[&loop]:character_name][/td][td style="width:175px"][c]No Effect[/c][/td]
	  --]|
	 --:BottomLoop|
	 --%|
	-->Finish|
  
  --:Finish|
   --~|hash;clear;Sleep

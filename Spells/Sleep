	--/|check for undead, check for immune, and evaluate outcome
	--%loop|foreach;inRange
	 --~hp|string;before;,;[&loop]
	 --~loop|string;after;,;[&loop]
	 --&Type|"[*[&loop]:npc_type]"
	 --&Immune|"[*[&loop]:npc_condition_immunities]"

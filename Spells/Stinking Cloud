   --&[%2%]|[@SpiritCharArr(0)]
   --<|
  
  --:CAST_SPELL|
   --+|Move Spell Token to desired location and then target it by casting the spell.
   --/| (1) Spawn the effect template and find the ID for it
   --!ot:NewTID|name:"[&SpellTargetToken]"|_pageid:[*S:t-_pageid]|left:[=[*S:t-left]+70]|top:[*S:t-top]|width:[*S:t-width]|height:[*S:t-height]|imgsrc:"[&URLlink]"|bar1_value:1|represents:"[&SpellTargetToken]"|showname:0|t-aura1_radius:20|t-aura1_color:#d0e0e3
   --z:graphic:[&NewTID]|tofront
   -->SetAbility|
   --+Target: |[rbutton]Target the Spell Token.::SetTarget;[&TB]target|token_id}[/rbutton]
   --X|
  
  --:SetTarget|
   --#targettoken|[&reentryval]
   --&SleepTarget|[*T:t-id]

  --:SetAbility|
   --~|array;objects:ability;AbilityArr;;[&AOETargetID]
    --!ability:[@AbilityArr(0)]|istokenaction:False
	--!ability:[@AbilityArr(1)]|istokenaction:False
	--!ability:[@AbilityArr(2)]|istokenaction:False
	--!ability:[@AbilityArr(3)]|istokenaction:False
   --<|
  
  --:Modtoken|
   --?[*S:npc] -eq 1 |[ 
	--~count|array;pagetokens;tokens;[*S:t-id];tprop:name=[&TokenName]
    --!graphic:[@tokens(0)]|gm_only_tooltip:1
	--]|
   -->FindTargets|
  
  --:FindTargets|
   --/|( GET ALL TOKENS INTO THE "allTokens" ARRAY will have blank 1st element to be removed later
   --~|array;pagetokens;allTokens;[*S:t-id]

   --/| CREATE THE "inRange" ARRAY TO HOLD TOKENS IN RANGE
   --~|array;define;inRange;
   --~|array;define;Failed;
   
   --/| PREP ARRAY FOR LOOP if no array elements then end macro
   --~tokenid|array;getfirst;allTokens
   --?[&tokenid] -eq ArrayError|End
   --/|(2) FIND ALL TOKENS IN AoE
   --:RangeLoop|
   --:/|TOKEN MUST BE ON OBJECTS OR GMLAYER AND TEMPLATE MUST OVERLAP AoE
   --?[*[&tokenid]:t-layer] -ne objects -and [*[&tokenid]:t-layer] -ne gmlayer|NextToken
   --?[&tokenid] -eq [&CloudTID]|NextToken   
   --?"X[*[&tokenid]:race]" -eq "X" -and "[*[&tokenid]:npc]" -ninc "1"|NextToken
   -->LibSN_CHECK_TOKEN_OVERLAP|[&CloudTID];[&tokenid];OLap
   --?[&OLap] -eq 0|NextToken
   
   --/|ADD TO THE "inRange" ARRAY
   --~|array;add;inRange;[&tokenid]
   
   --:NextToken|
   --~tokenid|array;getnext;allTokens
   --?[&tokenid] -ne ArrayError|RangeLoop
   
   --/|(3) REMOVE DUMMY FIRST ITEM IN inRange ARRAY and emote
   --~|array;removeat;inRange;0
   --?"X[@inRange(0)]" -eq "Xundefined array"|[
   --+|[c][b]No Targets in Range![/b][/c]
   -->Output|
   --]|
   -->SaveLoop|
   
  --:SaveLoop|
   --#whisper|
   --+|[t border=3 width=100%][tr][td style="width:100px"][c]Target[/c][/td][td style="width:50px"][c]Save[/c][/td][td style="width:30px"][c]P/F?[/c][/td][/tr]
   --%loop|foreach;inRange
    --&damageMod|
	--&BlessFlag|
    --&BaneMarkerFlag|
    --&GlobalSave|
    --&GlobalSkill|
    
	-->far_CheckDamageModifiers|[*[&loop]:character_id];[&damageType];damageMod;1;0;0
	
    --&saveDice|1d20
   
    --?"X[*[&loop]:race]" -ne "X"|[
     -->far_Check_GLOBAL_MOD_EXISTS|[*[&loop]:character_id]; save; [&damageType]; damageSave
     -->far_Check_GLOBAL_ATTRIB_SAVE_EXISTS|[*[&loop]:character_id]; [&attrib]; attribSaveRoll
     --?[&damageSave] -eq 1 -or [&attribSaveRoll] -eq 1 -and "[&saveDice]" -eqi "1d20"|&saveDice;2d20kh1
     --?[&damageSave] -eq 1 -or [&attribSaveRoll] -eq 1 -and "[&saveDice]" -eqi "2d20kl1"|&saveDice;1d20
    
     -->far_FIND_ACTIVE_GLOBAL_SAVE_MODS|[*[&loop]:character_id];GlobalSave
     -->far_FIND_ACTIVE_GLOBAL_SKILL_MODS|[*[&loop]:character_id];GlobalSkill
	 --]|
   
    -->LibSN_CHECK_STATUS_MARKER|[*[&loop]:t-id];[&BlessedMarker];BlessFlag;BlessCount
    -->LibSN_CHECK_STATUS_MARKER|[*[&loop]:t-id];[&BaneMarker];BaneMarkerFlag;BaneMarkerCount

    --?[&BaneMarkerFlag] -eq 1|&Baneroll;+ - 1d4 [Bane] |&Baneroll;
   
    --=TargetSave|[&saveDice] + [*[&loop]:[&attrib]_save_bonus] [&obrac][&Displayattrib][&cbrac] [&GlobalSave] [&GlobalSkill] [&Baneroll]
	
	--?"[&damageMod]" -inc "Immune"|[
	 --+|[t border=3 width=100%][tr][td style="width:100px"][c][*[&loop]:character_name][/c][/td][td style="width:50px"][c][b]Immune[/b][/c][/td][td style="width:30px"][c][/c][/td][/tr]
	 --^BottomCloudLoop|
	 --]|

	--?[$TargetSave] -lt [*S:spell_save_dc]|[
	 --+|[t border=3 width=100%][tr][td style="width:100px"][c][*[&loop]:character_name][/c][/td][td style="width:50px"][c][$TargetSave][/c][/td][td style="width:30px"][c]F[/c][/td][/tr]
	 -->LibSN_ADD_STATUS_MARKER|[*[&loop]:t-id];[&IncapMarker];1
	 --]|
	 
	--?[$TargetSave] -ge [*S:spell_save_dc]|[
	 --+|[t border=3 width=100%][tr][td style="width:100px"][c][*[&loop]:character_name][/c][/td][td style="width:50px"][c][$TargetSave][/c][/td][td style="width:30px"][c]P[/c][/td][/tr]
	 --]|
   
   --:BottomCloudLoop|
   --%|	
   -->Output|
  
  --:Output|
   --+|[br]
   --+Duration: |[&duration]
   --+Desc: |[&desc]
   -->far_DeductSpellSlot|[*S:t-id];[&MinimumSpellLevel]
   --X|
  
  --:Remove|
   --&TokenName|[*S:character_name] [&CharName]
   --~count|array;pagetokens;tokens;[*S:t-id];tprop:name=[&TokenName]
   --~|object;token;delete;[@tokens(0)]
   --#whisper|
   --#emotetext|[&CharName] vanishes!
   --+|[*S:character_name] is no longer concentrating.
   -->LibSN_REMOVE_STATUS_MARKER|[*S:t-id];[&ConcentrationMarker]

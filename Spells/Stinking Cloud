   -->far_GetAvailableSpellLevels|[*S:character_id];[&MinimumSpellLevel];SpellCastLevel
   --?[@SpellCastLevel(length)] -eq 0|>far_FatalError;No Spell Slots Available;ERROR;No spell slots are available to cast [&SpellName]
   
   -->GetCharID|"[&SpellTargetToken]";AOETargetID
   -->CAST_SPELL|
   --#emoteText|[*S:character_name] Casts [&SpellName]!
   --#leftsub|DC: [*S:spell_save_dc]
   --#rightsub|[*R:spellrange]
   --?[*R:spellconcentration] -inc 1|&duration;[*R:spellduration] [b](Concentration)[/b]|&duration;[*R:spellduration]
   --&desc|[*R:spelldescription]
   -->GetCharID|"[&CharName]";SummonID
   --!a:[&SummonID]|!SaveDC:[*S:spell_save_dc]
   --!a:[*S:character_id]|!ConcentrationSpell:[&TokenName]
   -->LibSN_ADD_STATUS_MARKER|[*S:t-id];[&ConcentrationMarker];10

   --/|SPAWN Stinking Cloud Token
   --:SpawnToken|
	--?[&SpawnScript] -eq 2|[
	 --@forselected+|Spawn _name|[&CharName] _qty|1 _targets|1,FX Spawn Selection _offset|0,0 _force|yes _size|10 _tokenProps|name:[&TokenName],showname:false,showplayers_name:false _order|toBack _bar1|KeepLink _fx|nova-magic _expand|15,30 {^&select [&TB]target|token_id[&cbrace]}
	 --]|
	 
	--?[&SpawnScript] -eq 1|[
	 --!ot:CloudTID|name:"[&TokenName]"|left:[*T:t-left]|top:[*T:t-top]|width:[=[*T:t-width]*10]|height:[=[*T:t-height]*10]|imgsrc:"[&Cloudlink]"|bar1_value:1|represents:[&SummonID]|showname:false|tooltip:DC [*S:spell_save_dc]|show_tooltip:true
	 --z:graphic:[&CloudTID]|toback
	 --]|
	 
   --~count|array;pagetokens;tokens;[*S:t-id];tprop:name=[&SpellTargetToken]
   --~|object;token;delete;[@tokens(0)]
	
	-->Modtoken|
    --X|
   
  --/| ____________________ Procedures_______________________________________________________________________________________
  
  --:GetCharID|CharacterName;StringVariableForCharID

    --?[$TargetSave] -lt [*S:spell_save_dc]|[
	 --+|[t border=3 width=100%][tr][td style="width:100px"][c][*[&loop]:character_name][/c][/td][td style="width:40px"][c][$TargetSave][/c][/td][td style="width:40px"][c]F[/c][/td][/tr]
 	 -->LibSN_ADD_STATUS_MARKER|[*[&loop]:t-id];[&FFMarker];
	 --!a:[*S:character_id]|!ConcentrationSpell:[&SpellName]
	 --!a:[*S:character_id]|!ConcentrationSpellTargetToken:[&FFTokenName]
	 --!a:[*[&loop]:character_id]|!MageID:[*S:character_id]
	 
	--?[&SpawnScript] -eq 1 -and "[&firecolor]" -inc "blue"|[
	 --!ot:FFTID|name:"[&FFTokenName]"|left:[*[&loop]:t-left]|top:[*[&loop]:t-top]|width:[*[&loop]:t-width]|height:[*[&loop]:t-height]|imgsrc:"[&BlueLink]"|bar1_value:1|represents:[&CharNameID]|showname:false|emits_low_light:true

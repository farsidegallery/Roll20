   --&TokenName|[*[&GraphicOld_id]:character_name] Bless
   --~count|array;pagetokens;tokens;[*[&GraphicOld_id]:t-id];tprop:name=[&TokenName]
   --%loop|foreach;tokens
	--~|object;token;delete;[*[&loop]:t-id]
	--%|
   --<|
  
  --:Faerie|
   --~|array;pagetokens;alltokens;[*[&GraphicOld_id]:t-id]

   --~DC|math;max;10;[$damage]
   --?"[*[&GraphicOld_id]:npc]" -ne "1"|PC
   --?[*[&GraphicOld_id]:npc] -eq 1 -and [*[&GraphicOld_id]:npc_con_save_flag] -gt 0|&Save;npc_con_save
    --=Save|1d20 + [*[&GraphicOld_id]:[&Save]] [CON]
	--?[$Save.Base] -eq 20|>Crit
	--?[$Save] -ge [$DC]|>Success |>Fail

  --:PC|
   --#whisper|[*[&GraphicOld_id]:character_name],gm
   --#emoteText|[*[&GraphicOld_id]:t-name] is Concentrating on a spell!

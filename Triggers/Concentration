   --~|object;token;delete;[@tokens(0)]
   --!a:[*[&GraphicOld_id]:character_id]|!ConcentrationSpell:**
   --X|

  
  --:Bane|
   --~|array;pagetokens;alltokens;[*[&GraphicOld_id]:t-id]
   --~|array;define;Bane
   --%loop|foreach;alltokens
   -->LibSN_CHECK_STATUS_MARKER|[*[&loop]:t-id];[&BaneMarker];BaneFlag;BaneCount
   --?[&BaneFlag] -eq 1|[
    --&Bane([@Bane(length)])|[*[&loop]:t-id]
    --]|
    --%|
   
   --%loop|foreach;Bane
    -->LibSN_REMOVE_STATUS_MARKER|[*[&loop]:t-id];[&BaneMarker]
	--%|   
   --<|
  
  --:Banishment|
   --~|array;pagetokens;alltokens;[*[&GraphicOld_id]:t-id]
   --~|array;define;Banished
   --%loop|foreach;alltokens
   -->LibSN_CHECK_STATUS_MARKER|[*[&loop]:t-id];[&BanishMarker];BanishFlag;BanishCount
   --?[&BanishFlag] -eq 1|[
    --&Banished([@Banished(length)])|[*[&loop]:t-id]
    --]|
    --%|
   
   --+|[br]
   --%loop|foreach;Banished
    -->LibSN_REMOVE_STATUS_MARKER|[*[&loop]:t-id];[&BanishMarker]
	--!t:[*[&loop]:t-id]|layer:objects
	--+|[*[&loop]:character_name] returns to the Material Plane!
	--%|
   --<|
  
  --:Bless|
   --~|array;pagetokens;alltokens;[*[&GraphicOld_id]:t-id]
   --~|array;define;Blessed
   --%loop|foreach;alltokens
    -->LibSN_CHECK_STATUS_MARKER|[*[&loop]:t-id];[&BlessMarker];BlessFlag;BlessCount
    --?[&BlessFlag] -eq 1 -and "[*[&loop]:Cleric_Bless]" -inc "[*[&GraphicOld_id]:character_id]"|[
    --&Blessed([@Blessed(length)])|[*[&loop]:t-id]
    --]|
    --%|
 
   --+|[br]
   --%loop|foreach;Blessed
    -->LibSN_REMOVE_STATUS_MARKER|[*[&loop]:t-id];[&BlessMarker]

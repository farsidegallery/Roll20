  --/|TRIGGER_REPLACEMENTS
  +++5Elib;snlib;Farsidelib+++
  
  --#reentrant|My Cool Script [*[&GraphicOld_id]:character_id]
  --&hitPointBar|1
  --&tempHPBar|4

  --?[&GraphicOldbar[&tempHPBar]_value] -gt 0|[
   --?[&GraphicOldbar[&tempHPBar]_value] -eq [&GraphicNewbar[&tempHPBar]_value]|SKIPTEMP
   --?[&GraphicNewbar[&tempHPBar]_value] -gt [&GraphicOldbar[&tempHPBar]_value]|SKIPTEMP
   --?[&GraphicNewbar[&tempHPBar]_value] -gt 0|Concentration
   --]|
  --:SKIPTEMP|
  
  --?[&GraphicOldbar[&hitPointBar]_value] -eq [&GraphicNewbar[&hitPointBar]_value]|SKIP
  --?[&GraphicNewbar[&hitPointBar]_value] -gt [&GraphicOldbar[&hitPointBar]_value]|SKIP
  --?"[&GraphicNewbar[&hitPointBar]_max]" -eq ""|SKIP
  --?"[&GraphicOldstatusmarkers]" -inc "dead"|SKIP
  --&newstatus|[&GraphicOldstatusmarkers],dead
  --?[&GraphicNewbar[&hitPointBar]_value] -le 0|SETSTATUS
  --?[&GraphicNewbar[&hitPointBar]_value] -gt 0|Concentration
  --?"X[&GraphicOldstatusmarkers]" -eq "X"|SETSTATUS
  
  --:SETSTATUS|
   --#hidecard|0
   --+Died: |[*[&GraphicOld_id]:character_name] died from the damage!
   --!t:[&GraphicOld_id]|statusmarkers:[&newstatus]
   --?"[&GraphicOldstatusmarkers]" -inc "&ConcentrationMarker"|>DeadEntry
   --X|
 
  --:SKIP|
   --X|
  
  --:Concentration|
   --?"[&GraphicOldstatusmarkers]" -ninc "[&ConcentrationMarker]"|SKIP
   -->far_PCConcenCheck|PCConcen;Scriptcheck
   --=Scriptcheck|[&Scriptcheck]
   --#hidecard|0
   --#title|Concentration Check
   --&SpellTokenName|[*[&GraphicOld_id]:ConcentrationSpell]

!script {{
  --/|This example watches for graphics objects (in this case tokens) to change. if the value that changed is the current hit points
  --/|(as specified by the hitPointBar variable below), it will be checked to see if it has hit 0. If so, the token will be marked 
  --/|with the "dead" status marker. If not, it will be checked for Concentration, and if needed, remove concentration spell affects and tokens.
  
  --#hidecard|1

--/| ____________________ Begin Global User Variables -Update the variables below to your game settings. ___________________________________ 
 
  --/|What token marker is used for the following?
  --&ConcentrationMarker|Concentrating::7409928
  --&InspirationMarker|Inspiration::7409921
  --&BlessedMarker|angel-outfit
  --&BardicMarker|BardicInspiration::7409920
  
  --/|What token marker is used for Bane?
  --&BaneMarker|Hexed3::7409911
  
  --/|What token marker is used for Banish?
  --&BanishMarker|Marked4::7409915
  
  --/|What token marker is used for Bless?
  --&BlessMarker|angel-outfit

  --/|Enter marker used for Charmed.
  --&HoldMarker|Paralyzed::7409941
  
  --/|Enter marker used for Faerie Fire.
  --&FFMarker|pink
  
  --/|Enter marker used for Hex.
  --&Hex|Hexed::7409913
  
  --/|What token marker is used for Hunter's Mark
  --&HuntMarked|Marked::7409918
  
  --/|What token marker is used for Invisibility Marker
  --&InvisMarker|Invisible::7409942
  
  --/|What token marker is used for Zephyr Strike
  --&zephyr|108-Range-Long::5818054
  
  --/|What is the name of the Global Attack Mod used for Bless?
  --&BlessAttack|Bless
  
  --/|What is the name of the Global Save Mod used for Bless?
  --&BlessSave|Bless
  
  --/|What is the name of the Global AC Mod used for Shield.
  --&ShieldName|Shield Spell
  
  --/|What is the name of the Global AC Mod used for Shield of Faith.
  --&FaithMod|Shield of Faith
  
  --/|Enter name used for Divine Favor Damage Mod.
  --&FavorName|Divine Favor
  
  --/|Enter name of the Global Damage Mod used for Holy Weapon.
  --&WeaponName|Holy Weapon
  
  --/|Enter name of the Global Damage Mod used for Hunter's Mark.
  --&HunterMark|Hunter's Mark
  
  --/|Enter name of the Global Damage Mod used for Zephyr's.
  --&zephyrstrike|Zephyr-Strike
  

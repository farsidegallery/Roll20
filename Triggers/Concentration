   --?[&BlessFlag] -eq 0 -and [&SaveExists] -eq 1|=Save;[$Save]+[$Guidance] [Guidance]
   --?[&BardicFlag] -eq 1|>Bardic
   --#whisper|
   --?[$Save] -ge [$DC]|>Success |>Fail
  
  --:Inspiration|characterid;tokenmarker;attackstring;attackstringreturn
   --?"[*[&GraphicOld_id]:inspiration]" -nei "on" -or "[&saveDice]" -nei "2d20kh1"|[
   --+|[c][b]Do you want to use your inspiration?[/b][/c]
   --+|[rbutton]Yes::InspirationRoll[/rbutton]  [rbutton]No::AnswerNo[/rbutton]
   --X|
   --]|
   --<|

  --:InspirationRoll|
   --?[&saveDice] -inc "1d20"|&saveDice;2d20kh1
   --?[&saveDice] -inc "2d20kl1"|&saveDice;1d20
   --!a:[*[&GraphicOld_id]:character_id]|inspiration:0
   -->LibSN_REMOVE_STATUS_MARKER|[*[&GraphicOld_id]:t-id];[&InspirationMarker]
   --<|
  
  --:Bardic|
   --?[&BardicFlag] -eq 1|[
   --?[$Scriptcheck] -nei 1|&BardPath;ChooseBard |&BardPath;ScriptBardEntry
   --+Save Roll|You rolled a [$Save] for your Saving Throw.  
   --+Do you want to use Bardic Inspiration?|[rbutton]Yes::[&BardPath][/rbutton][rbutton]No::AnswerNo[/rbutton]
   --X|
   --]|
   --<|
  

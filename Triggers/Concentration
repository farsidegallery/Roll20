   -->LibSN_CHECK_STATUS_MARKER|[*[&GraphicOld_id]:t-id];[&BlessedMarker];BlessFlag;BlessCount
   -->LibSN_CHECK_STATUS_MARKER|[*[&GraphicOld_id]:t-id];[&BardicMarker];BardicFlag;BardicCount
   -->far_Check_GLOBAL_MOD_EXISTS|[*[&GraphicOld_id]:character_id]; skill; Guidance; SaveExists
   --?[&PCConcen] -eq 1|[   
    --+Concentration: |[*[&GraphicOld_id]:character_name] took [$damage] hp of damage and needs to make a DC [$DC] concentration saving throw!
    --+|[br]
    --+|[b]Click here to roll the Concentration Saving Throw![/b]
    --+|[rbutton]Roll Saving Throw::PCContinue[/rbutton]
    --X|
	--]|
	-->PCContinue|
	--]| 
  
  --:PCContinue|
   --+|[c]Choose Saving Throw Type:[/c]
   --+|[c][rbutton]Advantage::RollSave;2d20kh1[/rbutton][rbutton]Normal::RollSave;1d20[/rbutton][rbutton]Disadvantage::RollSave;2d20kl1[/rbutton][/c]
   --X|
  
  --:RollSave|
   --&saveDice|[&reentryval]
   --=Bless|
   --=Guidance|
   --?[&InspiredFlag] -ne 0 |>Inspiration;[*[&GraphicOld_id]:character_id];[&InspirationMarker];[&saveDice];[&saveDice]
